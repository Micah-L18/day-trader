# Copy this file to `.env` and fill in real values. `.env` is git-ignored.
# NEVER commit real API keys.

# -----------------------------------------------------------------------------
# Trading mode: backtest | paper | live
# `live` additionally requires ALLOW_LIVE_TRADING=1 (see guardrails). Default
# is paper so nothing reaches a real account by accident.
# -----------------------------------------------------------------------------
TRADING_MODE=paper

# Live-trading safety interlock. Must be set to 1 *and* TRADING_MODE=live for
# the app to connect to a live brokerage account. Leave unset/0 otherwise.
ALLOW_LIVE_TRADING=0

# -----------------------------------------------------------------------------
# Alpaca credentials (paper and live use different keys -- generate from the
# Alpaca dashboard). Paper keys work against the paper endpoint only.
# -----------------------------------------------------------------------------
ALPACA_API_KEY=your_alpaca_key_id_here
ALPACA_SECRET_KEY=your_alpaca_secret_here
# Optional override; defaults are chosen automatically from TRADING_MODE.
# Paper: https://paper-api.alpaca.markets  Live: https://api.alpaca.markets
# ALPACA_BASE_URL=

# Market-data feed: iex (free) | sip (paid, full consolidated tape)
ALPACA_DATA_FEED=iex

# -----------------------------------------------------------------------------
# Trading universe & strategy (comma-separated symbols)
# -----------------------------------------------------------------------------
TRADING_SYMBOLS=AAPL,MSFT
TRADING_TIMEFRAME=1Min

# -----------------------------------------------------------------------------
# Risk limits (the chokepoint enforces these). All optional -- sane defaults
# are applied if unset. Keys are nested under RISK_.
# -----------------------------------------------------------------------------
RISK_MAX_POSITION_SHARES=1000
RISK_MAX_POSITION_NOTIONAL=25000
RISK_MAX_GROSS_EXPOSURE=100000
RISK_MAX_ORDER_NOTIONAL=25000
RISK_DAILY_LOSS_LIMIT=2000
RISK_MAX_ORDERS_PER_MINUTE=30
# Fraction (0-1) below entry for the protective stop attached to every entry.
RISK_STOP_LOSS_PCT=0.02

# -----------------------------------------------------------------------------
# Persistence & logging
# -----------------------------------------------------------------------------
DB_PATH=trading.db
LOG_LEVEL=INFO
LOG_DIR=logs
LOG_JSON=1
