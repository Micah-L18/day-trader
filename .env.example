# Copy to .env (git-ignored), or set these in the launching environment.
# Alpaca API keys are NOT set here — add them in-app (⚙ Settings), encrypted in
# the OS keychain.

# --- Live-trading gate (see PLAN.md §4 / CLAUDE.md) ---
# Real money requires ALL THREE: TRADING_MODE=live, ALLOW_LIVE_TRADING=1, AND an
# on-screen typed confirmation. Anything less stays on paper/sim. Default: off.
TRADING_MODE=paper
ALLOW_LIVE_TRADING=0
