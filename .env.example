# Copy to .env (git-ignored) and fill in. Never commit real keys.

# --- Alpaca (free paper account: https://alpaca.markets) ---
ALPACA_KEY_ID=your_paper_key_id_here
ALPACA_SECRET_KEY=your_paper_secret_here

# Paper is the default and the safe choice. Leave true.
ALPACA_PAPER=true

# --- Live-trading hard gate (see PLAN.md §4) ---
# Real money requires ALL of: app mode=live, this var = 1, and an on-screen
# typed confirmation. Keep at 0 for paper/sim.
ALLOW_LIVE_TRADING=0
